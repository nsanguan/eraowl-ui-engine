{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/alert.schema.json",
  "title": "Alert",
  "description": "Displays alerts, confirmations, and action-oriented messages",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "alertType": {
      "type": "string",
      "enum": [
        "info",
        "success",
        "warning",
        "danger"
      ],
      "default": "info"
    },
    "dismissible": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
