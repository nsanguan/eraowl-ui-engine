{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/reflowreport.schema.json",
  "title": "ReflowReport",
  "description": "Vertical card-style data display for small screens",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
