{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/inputtext.schema.json",
  "title": "InputText",
  "description": "Single-line text input field",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "label": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "placeholder": {
      "type": "string",
      "default": ""
    },
    "maxLength": {
      "type": "integer",
      "minimum": 0
    },
    "readOnly": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
