{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/charts.schema.json",
  "title": "Charts",
  "description": "Data visualization chart",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "chartType": {
      "type": "string",
      "enum": [
        "bar",
        "line",
        "pie",
        "area",
        "doughnut"
      ],
      "default": "bar"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
