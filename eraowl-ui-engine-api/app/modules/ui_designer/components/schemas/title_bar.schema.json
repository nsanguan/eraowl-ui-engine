{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/titlebar.schema.json",
  "title": "TitleBar",
  "description": "Groups breadcrumbs, page title, and primary page actions",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "breadcrumbs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
