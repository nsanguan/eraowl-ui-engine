{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/buttoncontainer.schema.json",
  "title": "ButtonContainer",
  "description": "Toolbar for organizing buttons and actions",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "align": {
      "type": "string",
      "enum": [
        "left",
        "center",
        "right",
        "between"
      ],
      "default": "left"
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
