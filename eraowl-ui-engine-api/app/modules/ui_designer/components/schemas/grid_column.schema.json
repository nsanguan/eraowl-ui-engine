{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/gridcolumn.schema.json",
  "title": "GridColumn",
  "description": "Vertical grid column \u2014 fraction of its parent GridRow",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "colSpan": {
      "type": "integer",
      "minimum": 1,
      "maximum": 12,
      "default": 1
    },
    "colOffset": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
