{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/regiondisplayselector.schema.json",
  "title": "RegionDisplaySelector",
  "description": "Show/hide toggle for page regions",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "title": {
      "type": "string"
    },
    "regionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
