{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/select.schema.json",
  "title": "Select",
  "description": "Dropdown select input",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "label": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "placeholder": {
      "type": "string",
      "default": "Select..."
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "multiple": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
