{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/interactivegrid.schema.json",
  "title": "InteractiveGrid",
  "description": "Editable data grid with inline editing",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "editable": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
