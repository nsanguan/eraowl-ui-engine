{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/classicreport.schema.json",
  "title": "ClassicReport",
  "description": "Tabular data report with columns and rows",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1,
      "default": 25
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
