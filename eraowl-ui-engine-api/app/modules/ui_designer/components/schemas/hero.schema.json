{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/hero.schema.json",
  "title": "Hero",
  "description": "Hero banner with icon, heading, sub-heading, and action buttons",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "icon": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "buttons": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "alignment": {
      "type": "string",
      "enum": [
        "left",
        "center",
        "right"
      ],
      "default": "center"
    }
  },
  "additionalProperties": false,
  "required": [
    "id"
  ]
}
