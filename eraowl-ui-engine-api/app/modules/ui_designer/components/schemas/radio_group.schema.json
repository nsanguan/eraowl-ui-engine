{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/radiogroup.schema.json",
  "title": "RadioGroup",
  "description": "Radio button group for single selection",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "label": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "value": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "id",
    "options"
  ]
}
