{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eraowl.dev/schemas/lov.schema.json",
  "title": "Lov",
  "description": "List-of-values data source component",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique component identifier"
    },
    "resolverName": {
      "type": "string"
    },
    "resolverParams": {
      "type": "object",
      "default": {}
    },
    "valueField": {
      "type": "string",
      "default": "value"
    },
    "labelField": {
      "type": "string",
      "default": "label"
    },
    "cache": {
      "type": "boolean",
      "default": true
    },
    "cacheTtl": {
      "type": "integer",
      "default": 300
    }
  },
  "additionalProperties": false,
  "required": [
    "id",
    "resolverName"
  ]
}
