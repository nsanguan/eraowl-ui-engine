# Database (External PostgreSQL)
DATABASE_URL=postgresql+asyncpg://eraowlui_admin:EraOwl2026@202.71.1.13:5435/eraowlui

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=eraowl-ui-engine-api

# Codegen
# TARGET_PROJECT_ROOT=/u01/eraowl-ops

# ─── AI Provider Configuration ───────────────────────────────────────────────
# Supported providers: openai, anthropic, google, azure, ollama, together, groq
AI_PROVIDER=openrouter
AI_API_KEY=your-openrouter-api-key-here
AI_MODEL=deepseek/deepseek-v4-flash
AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MAX_TOKENS=4096                       # Max response tokens
# AI_TEMPERATURE=0.7                       # 0.0 - 1.0
# AI_TIMEOUT=120                           # Request timeout in seconds

# AI Provider Fallback (optional — used if primary fails)
# AI_FALLBACK_PROVIDER=openai
# AI_FALLBACK_API_KEY=your-fallback-api-key
# AI_FALLBACK_MODEL=gpt-4o

# ─── AI Feature Flags ────────────────────────────────────────────────────────
# AI_CODEGEN_ENABLED=true                 # Enable AI-assisted codegen
# AI_LAYOUT_SUGGESTIONS=true              # Enable layout suggestions
# AI_COMPONENT_DISCOVERY=true             # Enable AI component discovery

# Logging
LOG_LEVEL=INFO
